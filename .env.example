# Root .env.example
# Copy to .env for local development. Per-app env lives under apps/*/.env.
# Real production values come from HashiCorp Vault, never from .env files.

# ---------- Web (apps/web) ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ALLOW_INDEXING=false
NEXT_PUBLIC_APP_VERSION=0.1.0

# Vercel-side HMAC signing of requests to FastAPI on Hetzner.
FASTAPI_URL=https://api.dev.strota.internal
FASTAPI_HMAC_SECRET=replace_with_vault_managed_secret_min_32_chars
FASTAPI_MTLS_CERT_PATH=/run/secrets/mtls-client.crt
FASTAPI_MTLS_KEY_PATH=/run/secrets/mtls-client.key

# ---------- API (apps/api-python) ----------
SERVICE_NAME=strota-api
ENVIRONMENT=development
LOG_LEVEL=INFO

HMAC_SECRET=replace_with_vault_managed_secret_min_32_chars
# HMAC_SECRET_PREVIOUS=  # set during 24h rotation overlap window
HMAC_SKEW_SECONDS=60
NONCE_TTL_SECONDS=120

REDIS_URL=redis://localhost:6379/0

# Comma-separated lowercase hex SHA-256 cert fingerprints. Empty disables mTLS gate (local dev only).
MTLS_ALLOWED_FINGERPRINTS=

# ---------- Future phases (placeholders, not used in Phase 1) ----------
