# Service identity
SERVICE_NAME=strota-api
ENVIRONMENT=development
LOG_LEVEL=INFO

# Inter-service auth (ADR-0002, v5.0 hardening ADR-0035)
# Min length 32 chars. Rotated monthly by CI cron. NEVER commit real values.
HMAC_SECRET=replace_with_vault_managed_secret_min_32_chars_long
# Optional: previous secret during rotation overlap window (24h).
# HMAC_SECRET_PREVIOUS=

HMAC_SKEW_SECONDS=60
NONCE_TTL_SECONDS=120

# Redis (BullMQ, nonce store, rate-limit counters)
REDIS_URL=redis://localhost:6379/0

# mTLS allowed client cert fingerprints (SHA-256 hex, lowercase, comma-separated)
# MTLS_ALLOWED_FINGERPRINTS=abc123...,def456...
